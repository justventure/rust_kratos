# Environment
APP_ENV=development

# Kratos
APP__KRATOS__ADMIN_URL=http://localhost:4434
APP__KRATOS__PUBLIC_URL=http://localhost:4433
APP__KRATOS__TIMEOUT_SECS=120
APP__KRATOS__CONNECT_TIMEOUT_SECS=30
APP__KRATOS__POOL_IDLE_TIMEOUT_SECS=120
APP__KRATOS__POOL_MAX_IDLE_PER_HOST=10
APP__KRATOS__MAX_RETRIES=3
APP__KRATOS__RETRY_DELAY_MS=1000
APP__KRATOS__ACCEPT_INVALID_CERTS=true
APP__KRATOS__KEEP_ALIVE_SECS=90
APP__KRATOS__KEEP_ALIVE_INTERVAL_SECS=20

# Server
APP__SERVER__HOST=127.0.0.1
APP__SERVER__PORT=8080
APP__SERVER__LOG_LEVEL=debug
APP__SERVER__CORS_ALLOWED_ORIGINS=*
APP__SERVER__MAX_CONNECTIONS=1000
APP__SERVER__MAX_CONCURRENT_REQUESTS=500

# Redis
APP__REDIS__URL=redis://127.0.0.1:6379
APP__REDIS__CACHE_TTL_SECS=300
APP__REDIS__MAX_RETRIES=5
APP__REDIS__RETRY_DELAY_MS=2000
APP__REDIS__KEEP_ALIVE_SECS=60

# Telemetry
APP__TELEMETRY__ENABLED=false
APP__TELEMETRY__OTLP_ENDPOINT=http://127.0.0.1:4317
APP__TELEMETRY__SERVICE_NAME=rust_kratos
